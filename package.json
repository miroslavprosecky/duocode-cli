{
  "name": "duocode",
  "version": "0.1.0",
  "description": "AI Pair Programming CLI – Claude implements, Codex supervises",
  "type": "module",
  "bin": {
    "duocode": "./dist/bin/duocode.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/bin/duocode.js",
    "lint": "tsc --noEmit",
    "bundle": "node scripts/build-exe.mjs",
    "build:exe": "npm run build && npm run bundle",
    "build:installer": "node scripts/build-installer.mjs",
    "build:all": "npm run build:exe && npm run build:installer"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["ai", "pair-programming", "claude", "codex", "cli"],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "openai": "^4.78.0",
    "commander": "^13.1.0",
    "inquirer": "^12.3.0",
    "simple-git": "^3.27.0",
    "chalk": "^5.4.1",
    "ora": "^8.1.1",
    "boxen": "^8.0.1",
    "zod": "^3.24.1",
    "diff": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/diff": "^6.0.0",
    "@types/inquirer": "^9.0.7",
    "esbuild": "^0.25.0",
    "postject": "^1.0.0-alpha.6",
    "typescript": "^5.7.0"
  }
}
